APP_NAME=Panga Branch API
APP_ENV=dev
DATABASE_URL=postgresql+psycopg2://panga:panga@localhost:5432/panga
REDIS_URL=redis://localhost:6379/0
BRANCH_BANK_NAME=Panga Branch Bank
BRANCH_BASE_URL=http://localhost:8081
CENTRAL_BANK_BASE_URL=https://test.diarainfra.com/central-bank
FALLBACK_BANK_ID=LOC001
HEARTBEAT_INTERVAL_SECONDS=600
SUPPORTED_CURRENCIES=EUR,USD,GBP,SEK,LVL
JWT_PRIVATE_KEY_PATH=./data/private_key.pem
JWT_PUBLIC_KEY_PATH=./data/public_key.pem
DIRECTORY_CACHE_TTL_SECONDS=300
PENDING_RETRY_MAX_SECONDS=3600
PENDING_TIMEOUT_SECONDS=14400
